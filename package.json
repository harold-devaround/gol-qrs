{
  "name": "gol-qrs",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json && node -e \"const{mkdirSync,copyFileSync}=require('fs');mkdirSync('dist/vendor',{recursive:true});copyFileSync('node_modules/fabric/dist/index.js','dist/vendor/fabric.js');\"",
    "postinstall": "tsc -p tsconfig.build.json",
    "lint": "eslint js/ tests/",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harold-devaround/gol-qrs.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/harold-devaround/gol-qrs/issues"
  },
  "homepage": "https://github.com/harold-devaround/gol-qrs#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "fabric": "^7.2.0"
  }
}
